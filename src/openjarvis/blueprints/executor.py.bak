#!/usr/bin/env python3
"""Blueprint executor — runs registered blueprints and writes real artifacts."""

from __future__ import annotations

import os
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Optional

from openjarvis.blueprints.registry import BlueprintDefinition
from openjarvis.blueprints.store import BlueprintStore


@dataclass(slots=True)
class BlueprintRunResult:
    blueprint_key: str
    status: str
    artifact_path: Optional[str]
    summary: str
    error: Optional[str] = None


class BlueprintExecutor:
    def __init__(self, store: BlueprintStore, artifacts_root: str | None = None) -> None:
        self.store = store
        self.artifacts_root = Path(artifacts_root or os.path.expanduser("~/.openjarvis/artifacts/blueprints"))
        self.artifacts_root.mkdir(parents=True, exist_ok=True)

    def run(self, definition: BlueprintDefinition, values: Optional[Dict[str, str]] = None) -> BlueprintRunResult:
        values = values or {}
        artifact_path = self._artifact_path(definition)
        try:
            text = self._execute(definition, values, artifact_path)
            self.store.log_artifact(definition.key, status="success", path=str(artifact_path), summary=text[:240])
            return BlueprintRunResult(
                blueprint_key=definition.key,
                status="success",
                artifact_path=str(artifact_path),
                summary=text,
            )
        except Exception as exc:
            self.store.log_artifact(definition.key, status="error", path=str(artifact_path), summary=str(exc))
            return BlueprintRunResult(
                blueprint_key=definition.key,
                status="error",
                artifact_path=str(artifact_path) if artifact_path.exists() else None,
                summary="",
                error=str(exc),
            )

    def _artifact_path(self, definition: BlueprintDefinition) -> Path:
        from datetime import datetime
        ts = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")
        return self.artifacts_root / f"{definition.key}_{ts}.md"

    def _execute(self, definition: BlueprintDefinition, values: Dict[str, str], artifact_path: Path) -> str:
        if definition.key == "custom-reminder":
            text = values.get("text") or definition.description
            artifact_path.write_text(text, encoding="utf-8")
            return text

        # Built-in executable contracts: write deterministic artifact content
        if definition.key in {"morning-brief", "evening-winddown", "workday-start", "weekly-review", "meal-plan"}:
            content = self._brief_content(definition, values)
            artifact_path.write_text(content, encoding="utf-8")
            return content

        if definition.key == "important-mail":
            content = self._mail_content(definition, values)
            artifact_path.write_text(content, encoding="utf-8")
            return content

        if definition.key == "news-digest":
            content = self._digest_content(definition, values)
            artifact_path.write_text(content, encoding="utf-8")
            return content

        if definition.key == "bill-renewal-watch":
            content = self._billing_content(definition, values)
            artifact_path.write_text(content, encoding="utf-8")
            return content

        if definition.key in {"habit-checkin", "gratitude-journal"}:
            content = self._reflection_content(definition, values)
            artifact_path.write_text(content, encoding="utf-8")
            return content

        if definition.key == "hydration-move":
            content = self._nudge_content(definition, values)
            artifact_path.write_text(content, encoding="utf-8")
            return content

        if definition.key == "learn-daily":
            content = self._lesson_content(definition, values)
            artifact_path.write_text(content, encoding="utf-8")
            return content

        if definition.key == "on-this-day":
            content = self._discovery_content(definition, values)
            artifact_path.write_text(content, encoding="utf-8")
            return content

        if definition.key == "kingwen-state-of-being":
            return self._kingwen_state_of_being(definition, values, artifact_path)

        content = definition.description
        artifact_path.write_text(content, encoding="utf-8")
        return content

    def _header(self, definition: BlueprintDefinition) -> str:
        return f"# {definition.title}\n\nGenerated by Jarvis blueprint `{definition.key}`.\n\n"

    def _brief_content(self, definition: BlueprintDefinition, values: Dict[str, str]) -> str:
        lines = [self._header(definition), "## Agenda\n\n- No calendar connector configured yet.\n- Add calendar source to enable real agenda extraction.\n\n## Weather\n\n- No weather source configured yet.\n- Add location to enable live weather.\n\n## Urgent items\n\n- No urgent items detected.\n\n## Notes\n\nThis is a deterministic artifact scaffold until upstream calendar/weather sources are wired.\n"]
        return "".join(lines)

    def _mail_content(self, definition: BlueprintDefinition, values: Dict[str, str]) -> str:
        return self._header(definition) + "## Needs attention\n\n- No urgent mail detected.\n\n## Informational\n\n- No mail scanned.\n\n*Real mailbox scan requires mail connector config.*\n"

    def _digest_content(self, definition: BlueprintDefinition, values: Dict[str, str]) -> str:
        topic = values.get("topic", "configured topic")
        return self._header(definition) + f"## Topic: {topic}\n\n- No new items found.\n- Dedup log not yet configured.\n\n*Deterministic placeholder until web search connector is wired.*\n"

    def _billing_content(self, definition: BlueprintDefinition, values: Dict[str, str]) -> str:
        return self._header(definition) + "## Upcoming 14 days\n\n- No billing ledger found.\n- Create a billing ledger file to enable renewal scanning.\n"

    def _reflection_content(self, definition: BlueprintDefinition, values: Dict[str, str]) -> str:
        return self._header(definition) + "## Reflection\n\n- Morning: What matters today?\n- Evening: What went well?\n- Habit: Tracked as self-reported.\n"

    def _nudge_content(self, definition: BlueprintDefinition, values: Dict[str, str]) -> str:
        return self._header(definition) + "## Nudge\n\n- Drink water.\n- Stand up.\n- Stretch.\n- Breathe.\n"

    def _lesson_content(self, definition: BlueprintDefinition, values: Dict[str, str]) -> str:
        topic = values.get("topic", "configured topic")
        return self._header(definition) + f"## Lesson: {topic}\n\n- Lesson 1: Start here.\n- Practice: Review this entry again in 24 hours.\n"

    def _discovery_content(self, definition: BlueprintDefinition, values: Dict[str, str]) -> str:
        return self._header(definition) + "## On this day\n\n- Notable item not yet wired to web source.\n- Discovery log will populate once web connector is configured.\n"

    def _kingwen_state_of_being(
        self,
        definition: BlueprintDefinition,
        values: Dict[str, str],
        artifact_path: Path,
    ) -> str:
        import json as _json
        import time as _time
        from pathlib import Path as _Path
        from openjarvis.server.kingwen.kingwen_client_sync import KingwenClientSync

        session_id = values.get("session_id", "blueprint-kingwen-state")
        text = values.get("text") or values.get("query") or definition.title
        domain = values.get("domain") or "blueprint/state-of-being"
        tool = values.get("tool") or "/blueprint/kingwen-state-of-being"

        tables_root = _Path(
            "C:/Users/krist/Desktop/KING-WEN-I-CHING-IMMUTABLE-TABLES"
        )
        hexagrams = []
        expansion = {"source": "local-immutable-tables", "expanded": [], "resolved": []}
        try:
            registry = _json.loads(
                (tables_root / "king_wen_64_verified.json").read_text(encoding="utf-8")
            )
            hexagrams = registry.get("hexagrams", [])
            collapse_payload = _json.loads(
                (tables_root / "collapse_full_128_output.json").read_text(encoding="utf-8")
            )
            expansion["expanded"] = collapse_payload.get("expanded", [])
            expansion["resolved"] = collapse_payload.get("resolved", [])
        except Exception as exc:
            expansion = {"source": "error", "error": str(exc), "expanded": [], "resolved": []}

        resolved = expansion.get("resolved") or []
        expanded = expansion.get("expanded") or []

        selected = None
        if resolved:
            def _score(entry):
                vec = entry.get("resolved_vector") or entry.get("expanded_vector") or {}
                return float(vec.get("voiceWeight", 0.0) or 0.0) + float(vec.get("coherence", 0.0) or 0.0)

            selected = sorted(resolved, key=_score, reverse=True)[0]

        lines = [
            self._header(definition),
            "## King Wen State of Being\n\n",
            f"- Session: {session_id}\n",
            f"- Source text: {text}\n",
            f"- Domain: {domain}\n",
            f"- Tool: {tool}\n",
            f"- Expansion source: {expansion.get('source') or 'unknown'}\n",
            f"- Expanded count: {len(expansion.get('expanded') or [])}\n",
            f"- Resolved count: {len(expansion.get('resolved') or [])}\n",
            "\n## Dominant State\n\n",
            f"- Hexagram: {hexagram_id or '—'}\n",
            f"- Phase: {phase or 'present'}\n",
            f"- Porosity: {porosity if porosity is not None else '—'}\n",
            "\n### Vectors\n\n",
            f"- voiceWeight: {float(vectors.get('voiceWeight') or 0):.3f}\n",
            f"- coherence: {float(vectors.get('coherence') or 0):.3f}\n",
            f"- chaos: {float(vectors.get('chaos') or 0):.3f}\n",
            f"- whimsy: {float(vectors.get('whimsy') or 0):.3f}\n",
            f"- darkTone: {float(vectors.get('darkTone') or 0):.3f}\n",
            "\n## Trigrams\n\n",
            f"- ☰ Qian (Heaven)\n",
            f"- ☱ Dui (Lake)\n",
            f"- ☲ Li (Fire)\n",
            f"- ☳ Zhen (Thunder)\n",
            f"- ☴ Xun (Wind)\n",
            f"- ☵ Kan (Water)\n",
            f"- ☶ Gen (Mountain)\n",
            f"- ☷ Kun (Earth)\n",
            "\n## Injection Result\n\n",
            f"```json\n{__import__('json').dumps(inject, indent=2)}\n```\n",
            "\n## Save State Before\n\n",
            f"```\n{state_before.get('saveString', '')}\n```\n",
        ]

        content = "".join(lines)
        artifact_path.write_text(content, encoding="utf-8")
        return content


__all__ = ["BlueprintRunResult", "BlueprintExecutor"]
